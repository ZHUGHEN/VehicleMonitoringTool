<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CarTelemetry.Desktop.ViewModels"
        xmlns:views="clr-namespace:CarTelemetry.Desktop.Views"
        xmlns:converters="clr-namespace:CarTelemetry.Desktop.Converters"
        x:Class="CarTelemetry.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1024" Height="600" 
        MinWidth="600" MinHeight="400"
        Title="Z33 Telemetry Dashboard"
        WindowStartupLocation="CenterScreen"
        CanResize="False">
        <!--WindowState="FullScreen"-->

  <!-- Window Resources -->
  <Window.Resources>
    <converters:RpmToColorConverter x:Key="RpmToColorConverter" />
    <converters:TransmissionStatusConverter x:Key="TransmissionStatusConverter" />
    <converters:TransmissionColorConverter x:Key="TransmissionColorConverter" />
  </Window.Resources>
  
  <!-- Main Layout -->
  <Grid>
    <!-- Main Content with Header and Tabs -->
    <Grid x:Name="TelemetryView" RowDefinitions="Auto,*">
      <Grid.Background>
          <ImageBrush Source="/Assets/dashboard-background.webp" 
                      Stretch="UniformToFill" 
                      Opacity="0.3" />
      </Grid.Background>
      
      <!-- Header -->
      <Border Grid.Row="0" 
              Background="rgba(0, 0, 0, 0.85)"
              Padding="20,16"
              BorderBrush="rgba(110, 0, 0, 0.81)"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="🚗" FontSize="24" Margin="0,0,12,0" />
            <TextBlock Text="Z33 Telemetry Dashboard" 
                       FontSize="20" 
                       FontWeight="SemiBold"
                       Foreground="White" 
                       VerticalAlignment="Center" />
          </StackPanel>
          
          <!-- Transmission Status Display (Read-only) -->
          <Border Grid.Column="1" 
                  Background="{Binding IsTransmitting, Converter={StaticResource TransmissionColorConverter}}"
                  BorderBrush="#DC2626"
                  BorderThickness="1"
                  Padding="12,8"
                  CornerRadius="6"
                  Margin="0,0,10,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="📡" FontSize="16" VerticalAlignment="Center" />
              <TextBlock Text="{Binding IsTransmitting, Converter={StaticResource TransmissionStatusConverter}}" 
                         FontSize="12" 
                         FontWeight="SemiBold"
                         Foreground="White"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Border>
          
          <!-- Settings Button -->
          <Button Grid.Column="2" 
                  Command="{Binding OpenSettingsCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="16"
                  CornerRadius="8"
                  MinWidth="48"
                  MinHeight="48"
                  ToolTip.Tip="Settings">
            <TextBlock Text="⚙️" 
                       FontSize="24" 
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Button>
        </Grid>
      </Border>

      <!-- Main Content Area with Navigation -->
      <Grid Grid.Row="1">
        <TabControl>
          
          <!-- Telemetry Tab -->
          <TabItem Header="📊 Telemetry">
            <!-- Content Area: Dynamic Gauge Grid -->
            <Grid RowDefinitions="*,Auto">

              <!-- Dynamic Gauge Grid -->
              <ItemsControl Grid.Row="0" ItemsSource="{Binding Gauges}" Margin="8">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <UniformGrid Rows="3" Columns="2" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <views:GaugeControl />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
        
              <!-- Footer/Status Bar inside telemetry tab -->
              <Border Grid.Row="1" 
                      Background="rgba(0, 0, 0, 0.85)"
                      BorderBrush="rgba(110, 0, 0, 0.81)"
                      BorderThickness="0,1,0,0"
                      Padding="20,12">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBlock Text="Real-time vehicle telemetry monitoring" 
                             FontSize="12"
                             Foreground="#6B7280"
                             VerticalAlignment="Center" />
                  
                  <StackPanel Grid.Column="1" 
                              Orientation="Horizontal" 
                              Spacing="10"
                              VerticalAlignment="Center">
                    <TextBlock Text="{Binding IsTransmitting, Converter={StaticResource TransmissionStatusConverter}, StringFormat={}Relay: {0}}"
                               FontSize="12"
                               Foreground="{Binding IsTransmitting, FallbackValue=#6B7280}"
                               VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                      <Ellipse.Fill>
                        <SolidColorBrush Color="{Binding IsTransmitting, Converter={StaticResource TransmissionColorConverter}}" />
                      </Ellipse.Fill>
                    </Ellipse>
                  </StackPanel>
                  
                  <TextBlock Grid.Column="2"
                             Text="{Binding LastUpdateTime, StringFormat={}Last Update: {0:HH:mm:ss}}"
                             FontSize="12"
                             Foreground="#6B7280"
                             VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Grid>
          </TabItem>
          
          <!-- Diagnostics Tab -->
          <TabItem Header="🔧 Diagnostics">
            <views:DiagnosticsView x:Name="DiagnosticsView" />
          </TabItem>
          
        </TabControl>
      </Grid>
    </Grid>
    
    <!-- Settings View (Full Screen Overlay) -->
    <Grid x:Name="SettingsView" IsVisible="False" Background="Black">
      <!-- Settings Header with Back Button -->
      <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" 
                Background="rgba(0, 0, 0, 0.85)"
                Padding="20,16"
                BorderBrush="rgba(110, 0, 0, 0.81)"
                BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="Auto,*">
            <!-- Back Button -->
            <Button Grid.Column="0" 
                    Command="{Binding GoBackCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="16"
                    CornerRadius="8"
                    MinWidth="48"
                    MinHeight="48"
                    ToolTip.Tip="Back">
              <TextBlock Text="◀️" 
                         FontSize="24" 
                         Foreground="White"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Button>
            
            <!-- Settings Title -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
              <TextBlock Text="⚙️" FontSize="24" Margin="0,0,12,0" />
              <TextBlock Text="Settings" 
                         FontSize="20" 
                         FontWeight="SemiBold"
                         Foreground="White" 
                         VerticalAlignment="Center" />
            </StackPanel>
          </Grid>
        </Border>
        
        <!-- Settings Content -->
        <ContentControl Grid.Row="1" x:Name="SettingsContent" />
      </Grid>
    </Grid>
  </Grid>
</Window>
