<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CarTelemetry.Desktop.ViewModels"
        xmlns:views="clr-namespace:CarTelemetry.Desktop.Views"
        xmlns:converters="clr-namespace:CarTelemetry.Desktop.Converters"
        x:Class="CarTelemetry.Desktop.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Width="1024" Height="600"
        MinWidth="600" MinHeight="400"
        Title="Z33 Telemetry Dashboard"
        WindowStartupLocation="CenterScreen"
        CanResize="False">

  <Window.Resources>
    <converters:RpmToColorConverter x:Key="RpmToColorConverter" />
    <converters:TransmissionStatusConverter x:Key="TransmissionStatusConverter" />
    <converters:TransmissionColorConverter x:Key="TransmissionColorConverter" />
  </Window.Resources>

  <!-- Root shell: dashboard, settings overlay, and screensaver overlay share this surface. -->
  <Grid>
    <!-- Main dashboard view: header plus tabbed content. -->
    <Grid x:Name="TelemetryView" RowDefinitions="Auto,*">
      <Grid.Background>
          <ImageBrush Source="/Assets/dashboard-background.webp"
                      Stretch="UniformToFill"
                      Opacity="0.3" />
      </Grid.Background>

      <!-- Dashboard header: app title, center screensaver button, relay/settings controls. -->
      <Border Grid.Row="0"
              Background="rgba(0, 0, 0, 0.85)"
              Padding="20,16"
              BorderBrush="rgba(110, 0, 0, 0.81)"
              BorderThickness="0,0,0,1">
        <Grid ColumnDefinitions="*,Auto,*">
          <!-- App title. -->
          <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="🚗" FontSize="24" Margin="0,0,12,0" />
            <TextBlock Text="Z33 Telemetry Dashboard"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="White"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- Screensaver button: Nismo logo activates the full-screen clock view. -->
          <Button Grid.Column="1"
                  Command="{Binding OpenScreensaverCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="8"
                  CornerRadius="8"
                  MinWidth="140"
                  MinHeight="64"
                  HorizontalAlignment="Center"
                  ToolTip.Tip="Screensaver">
            <Image Source="avares://cartelemetry.desktop/Assets/nismo-seeklogo_whte2.png"
                   Width="140"
                   Height="64"
                   Stretch="Uniform" />
          </Button>

          <!-- Header actions: relay state indicator and settings button. -->
          <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="12">
            <!-- Relay status indicator. -->
            <Border Background="{Binding IsTransmitting, Converter={StaticResource TransmissionColorConverter}}"
                    BorderBrush="#DC2626"
                    BorderThickness="1"
                    Padding="12,8"
                    CornerRadius="6">
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="📡" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Text="{Binding IsTransmitting, Converter={StaticResource TransmissionStatusConverter}}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="White"
                           VerticalAlignment="Center" />
              </StackPanel>
            </Border>

            <!-- Open settings overlay button. -->
            <Button Command="{Binding OpenSettingsCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="16"
                    CornerRadius="8"
                    MinWidth="48"
                    MinHeight="48"
                    ToolTip.Tip="Settings">
              <TextBlock Text="⚙️"
                         FontSize="24"
                         Foreground="White"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Main tabs: telemetry gauges, lap timer, and diagnostics. -->
      <Grid Grid.Row="1">
        <TabControl>

          <!-- Telemetry tab: live configurable gauge grid. -->
          <TabItem Header="Telemetry">
            <Grid RowDefinitions="*,Auto">

              <!-- Gauge grid: six slots driven by the persisted gauge configuration. -->
              <ItemsControl Grid.Row="0" ItemsSource="{Binding Gauges}" Margin="8">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <UniformGrid Rows="3" Columns="2" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <views:GaugeControl />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>

              <!-- Dashboard footer: relay summary and last update timestamp. -->
              <Border Grid.Row="1"
                      Background="rgba(0, 0, 0, 0.85)"
                      BorderBrush="rgba(110, 0, 0, 0.81)"
                      BorderThickness="0,1,0,0"
                      Padding="20,12">
                <Grid ColumnDefinitions="*,Auto,Auto">
                  <TextBlock Text="Real-time vehicle telemetry monitoring"
                             FontSize="12"
                             Foreground="#6B7280"
                             VerticalAlignment="Center" />

                  <StackPanel Grid.Column="1"
                              Orientation="Horizontal"
                              Spacing="10"
                              VerticalAlignment="Center">
                    <TextBlock Text="{Binding IsTransmitting, Converter={StaticResource TransmissionStatusConverter}, StringFormat={}Relay: {0}}"
                               FontSize="12"
                               Foreground="{Binding IsTransmitting, FallbackValue=#6B7280}"
                               VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                      <Ellipse.Fill>
                        <SolidColorBrush Color="{Binding IsTransmitting, Converter={StaticResource TransmissionColorConverter}}" />
                      </Ellipse.Fill>
                    </Ellipse>
                  </StackPanel>

                  <TextBlock Grid.Column="2"
                             Text="{Binding LastUpdateTime, StringFormat={}Last Update: {0:HH:mm:ss}}"
                             FontSize="12"
                             Foreground="#6B7280"
                             VerticalAlignment="Center" />
                </Grid>
              </Border>
            </Grid>
          </TabItem>

          <!-- Lap timer tab. -->
          <TabItem Header="Lap Timer">
            <views:LapTimerView x:Name="LapTimerView" />
          </TabItem>

          <!-- Diagnostics tab. -->
          <TabItem Header="Diagnostics">
            <views:DiagnosticsView x:Name="DiagnosticsView" />
          </TabItem>

          <!-- Service records tab. -->
          <TabItem Header="Service Records">
            <views:ServiceRecordsView x:Name="ServiceRecordsView" />
          </TabItem>

        </TabControl>
      </Grid>
    </Grid>

    <!-- Settings overlay: replaces the dashboard when IsShowingSettings is true. -->
    <Grid x:Name="SettingsView" IsVisible="False" Background="Black">
      <Grid RowDefinitions="Auto,*">
        <!-- Settings overlay header with back navigation. -->
        <Border Grid.Row="0"
                Background="rgba(0, 0, 0, 0.85)"
                Padding="20,16"
                BorderBrush="rgba(110, 0, 0, 0.81)"
                BorderThickness="0,0,0,1">
          <Grid ColumnDefinitions="Auto,*">
            <!-- Back to dashboard button. -->
            <Button Grid.Column="0"
                    Command="{Binding GoBackCommand}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="16"
                    CornerRadius="8"
                    MinWidth="48"
                    MinHeight="48"
                    ToolTip.Tip="Back">
              <TextBlock Text="◀️"
                         FontSize="24"
                         Foreground="White"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Button>

            <!-- Settings title. -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
              <TextBlock Text="⚙️" FontSize="24" Margin="0,0,12,0" />
              <TextBlock Text="Settings"
                         FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="White"
                         VerticalAlignment="Center" />
            </StackPanel>
          </Grid>
        </Border>

        <!-- Settings content is created in code-behind so it can use its own ViewModel. -->
        <ContentControl Grid.Row="1" x:Name="SettingsContent" />
      </Grid>
    </Grid>

    <!-- Screensaver overlay: transparent tap target exits back to the dashboard. -->
    <Grid x:Name="ScreensaverView" IsVisible="{Binding IsShowingScreensaver}" Background="#0F0F0F">
      <views:ScreensaverView DataContext="{Binding}" />
    </Grid>

  </Grid>
</Window>
